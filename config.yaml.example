# Single source of truth for non-secret configuration.
#
# Layering (last wins):
#   config.yaml           -> base, committed
#   config.local.yaml     -> personal override, gitignored
#   env vars              -> secrets + per-run overrides
#
# Secrets (PRIVATE_KEY, KEEPER_PRIVATE_KEY, VOTE_ENCRYPTION_KEY) and optionally
# DATABASE_URL come from env — never from YAML. Set ONCHAIN_NOVEL_CONFIG to
# point at a different YAML file (deployment).
#
# Full reference: docs/config.md.

chain:
  rpcUrl: http://127.0.0.1:8545
  # nativeCurrency: defaults to Ether/ETH/18 (correct for anvil/mainnet/sepolia/base).
  # Override only for non-ETH chains. Drives UI symbol + RainbowKit wallet display.
  # nativeCurrency:
  #   name: Gravity
  #   symbol: G
  #   decimals: 18

  # Only `novelCore` is configured here. Every other contract (RoundManager,
  # VotingEngine, PrizePool, RulesEngine, BountyBoard, UserRegistry) is reachable
  # from NovelCore's on-chain address book and resolved at startup. Don't edit
  # this by hand — scripts/deploy.sh writes it after `forge script Deploy.s.sol`.
contracts:
  novelCore: "0x610178dA211FEF7D417bC0e6FeD39F05609AD788"

backend:
  host: 0.0.0.0
  port: 3001
  databaseUrl: postgresql://127.0.0.1:5432/onchain_novel
  indexer:
    startBlock: 0
    pollIntervalMs: 1000
    confirmationBlocks: 0
    batchSize: 100
  keeper:
    pollIntervalMs: 10000
frontend:
  port: 3000
  # Where SSR and the /api rewrite target the backend (same host, loopback).
  backendUrl: http://127.0.0.1:3001
  # Extra dev-server origins for cross-origin HMR (LAN testing). Empty =
  # same-origin only. Add hostnames like "192.168.1.2" if you access dev from
  # a phone on your LAN. Wildcards supported.
  allowedDevOrigins:
    - "127.0.0.1"
    - "localhost"
    - "192.168.*"
cli:
  apiUrl: http://127.0.0.1:3001
